{
  "name": "atelier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Atelier — 이미지 붙여넣기가 되는 GUI 터미널",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && npm run tauri:trust",
    "tauri:trust": "xattr -dr com.apple.quarantine src-tauri/target/release/bundle/macos/Atelier.app 2>/dev/null; codesign -s 'Atelier Local Code Signing' --deep --force --identifier com.atelier.app src-tauri/target/release/bundle/macos/Atelier.app 2>/dev/null && echo 'Atelier.app signed with stable cert (TCC 권한 영구 유지)' || codesign -s - --deep --force src-tauri/target/release/bundle/macos/Atelier.app 2>/dev/null; echo done"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.2.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
