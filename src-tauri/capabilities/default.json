{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Atelier 기본 권한",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-read-file",
    "clipboard-manager:default",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
